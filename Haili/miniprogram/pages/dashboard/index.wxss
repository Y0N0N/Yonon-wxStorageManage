
.dashboard {
  height: 100vh;
  background: var(--color-bg);
}

.header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 96rpx var(--spacing-md) var(--spacing-sm);
  background: linear-gradient(135deg, #667eea 0%, #4A90D9 100%);
  color: #fff;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.header-subtitle {
  font-size: var(--font-sm);
  opacity: 0.85;
  margin-left: 8rpx;
}

.header-right {
  font-size: var(--font-sm);
}
.logout-text {
  color: rgba(255,255,255,0.85);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
}
.logout-text:active { opacity: 0.7; background: rgba(255,255,255,0.1); }

/* 用户信息 */
.user-info-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md) 0;
}
.user-info-name {
  font-size: var(--font-lg);
  font-weight: 600;
}
.user-info-role {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.user-info-role.role-admin { background: #FFF7E6; color: #D48806; }
.user-info-role.role-assistant { background: var(--color-primary-light); color: var(--color-primary); }

/* 统计两列 */
.stats-row {
  display: flex;
  flex-direction: row;
  padding: var(--spacing-sm) var(--spacing-sm) 0;
  gap: 0;
}

.stat-card {
  flex: 1;
  background: #fff;
  margin: 8rpx;
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.stat-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  line-height: 1.2;
}

.stat-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.stat-blue .stat-value { color: var(--color-primary); }
.stat-green .stat-value { color: var(--color-success); }
.stat-orange .stat-value { color: var(--color-warning); }
.stat-red .stat-value { color: var(--color-danger); }
.stat-gray .stat-value { color: var(--color-text-light); }

.section {
  margin-top: var(--spacing-sm);
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md) var(--spacing-xs);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
}

.section-more {
  font-size: var(--font-sm);
  color: var(--color-primary);
}

.category-list {
  padding: 0 var(--spacing-sm);
}

.category-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-xs);
  border-bottom: 1rpx solid var(--color-border);
}

.category-item:last-child {
  border-bottom: none;
}

.category-name {
  font-size: var(--font-md);
  font-weight: 500;
}

.category-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.category-stock, .category-total {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.category-stock .num {
  color: var(--color-primary);
  font-weight: 600;
}

.category-divider {
  color: var(--color-border);
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 var(--spacing-sm);
}

.action-card {
  flex: 1;
  min-width: calc(33.33% - 16rpx);
  background: var(--color-card);
  margin: 8rpx;
  padding: var(--spacing-md) var(--spacing-sm);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-card:active {
  opacity: 0.7;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  text-align: center;
}

.timeline {
  padding: var(--spacing-sm) 0;
  margin: 0 var(--spacing-md);
}

.timeline-item {
  display: flex;
  flex-direction: row;
  padding: var(--spacing-sm) var(--spacing-md);
  position: relative;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-top: 10rpx;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.timeline-item:not(:last-child) .timeline-dot::after {
  content: '';
  display: block;
  width: 2rpx;
  height: calc(100% + 20rpx);
  background: var(--color-border);
  margin: 16rpx auto 0;
}

.timeline-content {
  flex: 1;
  min-width: 0;
}

.timeline-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.timeline-icon {
  flex-shrink: 0;
}

.timeline-detail {
  font-size: var(--font-sm);
  color: var(--color-text);
}

.timeline-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  margin-top: 6rpx;
}

.timeline-operator {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.timeline-time {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.empty-hint {
  text-align: center;
  color: var(--color-text-light);
  padding: var(--spacing-xl);
  font-size: var(--font-sm);
}

.bottom-safe {
  height: 40rpx;
}
