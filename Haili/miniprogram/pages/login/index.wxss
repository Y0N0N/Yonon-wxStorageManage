.login-page {
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #4A90D9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.login-container {
  width: 100%;
  padding: 0 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头部 */
.login-header {
  text-align: center;
  margin-bottom: 48rpx;
  width: 100%;
}

.login-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
  display: block;
}

.login-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  display: block;
}

.login-subtitle {
  font-size: var(--font-md);
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
  display: block;
}

/* 表单卡片 */
.login-form {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.12);
  width: 100%;
  max-width: 600rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: var(--font-md);
  color: var(--color-text);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.form-input {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: var(--font-lg);
  color: var(--color-text);
  border: 2rpx solid var(--color-border);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--color-primary);
  background: #fff;
}

.placeholder {
  color: var(--color-text-light);
  font-size: var(--font-lg);
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #4A90D9);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  border: none;
  letter-spacing: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.4);
}

.login-btn.loading {
  opacity: 0.7;
}

.login-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}

/* 底部提示 */
.login-footer {
  text-align: center;
  margin-top: 32rpx;
  width: 100%;
}

.login-footer text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}
