<scroll-view class="page" scroll-y="true">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack"><text>‹ 返回</text></view>
    <text class="nav-title">账号管理</text>
    <view class="nav-right" bindtap="onAdd"><text class="nav-add">+ 新增</text></view>
  </view>

  <view class="content">
    <view class="user-card card" wx:for="{{users}}" wx:key="id" data-id="{{item.id}}">
      <view class="user-top">
        <view class="user-info">
          <view class="user-name-row">
            <text class="user-name">{{item.name}}</text>
            <view class="user-role-tag {{item.role}}">
              {{item.roleLabel}}
            </view>
            <view class="status-tag {{item.statusClass}}">
              {{item.statusLabel}}
            </view>
            <text class="user-self" wx:if="{{item.isSelf}}">（当前）</text>
          </view>
          <text class="user-username">账号：{{item.username}}</text>
          <text class="user-phone" wx:if="{{item.phone}}">电话：{{item.phone}}</text>
        </view>
      </view>

      <!-- 操作按钮（仅对学生助理） -->
      <view class="user-actions" wx:if="{{item.role === 'assistant'}}">
        <view class="action-btn edit" data-id="{{item.id}}" bindtap="onEdit">编辑</view>
        <view class="action-btn {{item.isActive ? 'disable' : 'enable'}}"
          data-id="{{item.id}}" bindtap="onToggleActive">
          {{item.isActive ? '禁用' : '启用'}}
        </view>
        <view class="action-btn delete" data-id="{{item.id}}" bindtap="onDelete">删除</view>
      </view>
    </view>
  </view>

  <!-- 新增/编辑弹窗 -->
  <view class="modal-mask {{showModal ? 'visible' : ''}}" bindtap="closeModal"></view>
  <view class="modal {{showModal ? 'visible' : ''}}">
    <view class="modal-header">
      <text class="modal-title">{{modalTitle}}</text>
      <text class="modal-close" bindtap="closeModal">✕</text>
    </view>

    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">账号 <text class="required">*</text></text>
        <input cursor-spacing="300" class="form-input" type="text" placeholder="登录账号" placeholder-class="ph"
          value="{{form.username}}" data-field="username" bindinput="onFieldInput" />
      </view>

      <view class="form-group">
        <text class="form-label">密码 <text class="required">*{{form.id ? '（留空不修改）' : ''}}</text></text>
        <input cursor-spacing="300" class="form-input" type="text" password="{{true}}" placeholder="登录密码" placeholder-class="ph"
          value="{{form.password}}" data-field="password" bindinput="onFieldInput" />
      </view>

      <view class="form-group">
        <text class="form-label">姓名 <text class="required">*</text></text>
        <input cursor-spacing="300" class="form-input" type="text" placeholder="显示姓名" placeholder-class="ph"
          value="{{form.name}}" data-field="name" bindinput="onFieldInput" />
      </view>

      <view class="form-group">
        <text class="form-label">电话</text>
        <input cursor-spacing="300" class="form-input" type="text" placeholder="可选" placeholder-class="ph"
          value="{{form.phone}}" data-field="phone" bindinput="onFieldInput" />
      </view>
    </view>

    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeModal">取消</button>
      <button class="modal-btn confirm" bindtap="onSave" disabled="{{saving}}">
        {{saving ? '保存中...' : '保存'}}
      </button>
    </view>
  </view>

  <view class="bottom-safe"></view>
</scroll-view>
