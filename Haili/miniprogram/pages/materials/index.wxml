<scroll-view class="page" scroll-y="true">
  <!-- 自定义导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text>‹ 返回</text>
    </view>
    <text class="nav-title">物资目录</text>
    <view class="nav-right" bindtap="toggleSearch">
      <text>{{showSearch ? '取消' : '🔍'}}</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar {{showSearch ? 'visible' : ''}}">
    <input
      class="search-input"
      type="text"
      placeholder="搜索物资名称或类别..."
      placeholder-class="placeholder"
      value="{{searchKey}}"
      bindinput="onSearchInput"
      focus="{{showSearch}}"
    />
  </view>

  <!-- 物资列表 -->
  <view class="content">
    <view
      class="material-card card"
      wx:for="{{materials}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onMaterialTap"
    >
      <view class="material-top">
        <view class="material-info">
          <text class="material-name">{{item.name}}</text>
          <text class="material-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
        </view>
        <view class="material-category">{{item.category}}</view>
      </view>

      <view class="material-stats">
        <view class="stat-item">
          <text class="stat-num">{{item.currentStock}}</text>
          <text class="stat-label">在库 {{item.unit}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-num gray">{{item.totalQuantity - item.currentStock}}</text>
          <text class="stat-label">已借出</text>
        </view>
        <view class="stat-item">
          <text class="stat-num light">{{item.totalQuantity}}</text>
          <text class="stat-label">总量</text>
        </view>
      </view>

      <!-- 库存进度条 -->
      <view class="stock-bar">
        <view class="stock-fill" style="width: {{item.stockPercent}}%"></view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{materials.length === 0}}">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无物资</text>
    </view>
  </view>

  <!-- 新增按钮（仅助理） -->
  <view class="fab {{isAssistant ? '' : 'hidden'}}" bindtap="onAdd">
    <text class="fab-icon">+</text>
  </view>

  <view class="bottom-safe"></view>
</scroll-view>
