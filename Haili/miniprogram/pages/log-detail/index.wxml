<scroll-view class="page" scroll-y="true">
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack"><text>‹ 返回</text></view>
    <text class="nav-title">日志详情</text>
    <view class="nav-right"></view>
  </view>

  <view class="content" wx:if="{{log}}">
    <!-- 头部 -->
    <view class="detail-header card">
      <view class="header-icon" style="background: {{typeConfig.color}}20; color: {{typeConfig.color}}">
        {{typeConfig.icon}}
      </view>
      <view class="header-info">
        <text class="header-type">{{typeConfig.label}}</text>
        <text class="header-activity" wx:if="{{log.activityName}}">「{{log.activityName}}」</text>
        <text class="header-time">{{log.timestamp}} {{weekDay}}</text>
      </view>
      <view class="header-operator">{{log.operatorName}}</view>
    </view>

    <!-- 基本信息 -->
    <view class="info-section card">
      <view class="section-title">基本信息</view>
      <view class="info-row">
        <text class="info-label">操作类型</text>
        <text class="info-value tag">{{typeConfig.label}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">操作人</text>
        <text class="info-value">{{log.operatorName}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">操作时间</text>
        <text class="info-value">{{log.timestamp}} {{weekDay}}</text>
      </view>
      <view class="info-row" wx:if="{{log.relatedPerson}}">
        <text class="info-label">关联人员</text>
        <text class="info-value">{{log.relatedPerson}}</text>
      </view>
    </view>

    <!-- 活动详情（借出/归还是有） -->
    <view class="info-section card" wx:if="{{activity && (log.operationType === 'activity_borrow' || log.operationType === 'activity_return')}}">
      <view class="section-title">活动详情</view>

      <view class="info-row">
        <text class="info-label">活动名称</text>
        <text class="info-value strong">{{activity.activityName}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">举办时间</text>
        <text class="info-value">{{activity.holdDate}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">主办单位</text>
        <text class="info-value">{{activity.organizer}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">申请单位</text>
        <text class="info-value">{{activity.borrower}}</text>
      </view>
      <view class="info-row" wx:if="{{activity.note}}">
        <text class="info-label">物资用途</text>
        <text class="info-value">{{activity.note}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">联系人及联系方式</text>
        <text class="info-value">{{activity.contactPerson}} {{activity.contactPhone}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">借出时间</text>
        <text class="info-value">{{activity.borrowTime}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">预计归还</text>
        <text class="info-value">{{activity.expectedReturnTime}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">负责人</text>
        <text class="info-value">{{activity.responsiblePerson}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">学生助理</text>
        <text class="info-value">{{activity.assistantName}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">状态</text>
        <text class="info-value"><text class="status-badge {{activity.statusBadgeClass}}">{{activity.statusBadgeText}}</text></text>
      </view>
      <view class="info-row" wx:if="{{activity.actualReturnTime}}">
        <text class="info-label">实际归还</text>
        <text class="info-value">{{activity.actualReturnTime}}</text>
      </view>
    </view>

    <!-- 物资清单（借出/归还是有活动物资明细） -->
    <view class="info-section card" wx:if="{{activityItems.length > 0}}">
      <view class="section-title">物资清单</view>
      <view class="item-list">
        <view class="item-row" wx:for="{{activityItems}}" wx:key="id">
          <text class="item-name">{{item.materialName}}</text>
          <view class="item-qty-info">
            <text class="item-borrow">借出 {{item.quantity}}{{item.unit}}</text>
            <text class="item-return" wx:if="{{item.returnedQuantity > 0}}">已还 {{item.returnedQuantity}}{{item.unit}}</text>
            <text class="item-pending" wx:if="{{item.quantity - item.returnedQuantity > 0}}">待还 {{item.quantity - item.returnedQuantity}}{{item.unit}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 物资变动详情 -->
    <view class="info-section card" wx:if="{{log.operationType === 'material_change'}}">
      <view class="section-title">物资变动详情</view>
      <view class="info-row">
        <text class="info-label">物资名称</text>
        <text class="info-value strong">{{log.materialName}}</text>
      </view>
      <view class="info-row" wx:if="{{log.quantityChange}}">
        <text class="info-label">数量变化</text>
        <text class="info-value {{log.quantityChange > 0 ? 'green' : 'red'}}">
          {{log.quantityChange > 0 ? '+' : ''}}{{log.quantityChange}}
        </text>
      </view>
      <view class="info-row" wx:if="{{material}}">
        <text class="info-label">当前库存</text>
        <text class="info-value">{{material.currentStock}}{{material.unit}}</text>
      </view>
    </view>

    <!-- 完整描述 -->
    <view class="info-section card">
      <view class="section-title">完整记录</view>
      <view class="raw-detail">{{log.detail}}</view>
    </view>

    <!-- 快照（编辑类） -->
    <view class="info-section card" wx:if="{{log.beforeSnapshot || log.afterSnapshot}}">
      <view class="section-title">操作快照</view>
      <view class="snapshot" wx:if="{{log.beforeSnapshot}}">
        <text class="snapshot-label">修改前：</text>
        <text class="snapshot-data">{{JSON.stringify(log.beforeSnapshot)}}</text>
      </view>
      <view class="snapshot" wx:if="{{log.afterSnapshot}}">
        <text class="snapshot-label">修改后：</text>
        <text class="snapshot-data">{{JSON.stringify(log.afterSnapshot)}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-safe"></view>
</scroll-view>
