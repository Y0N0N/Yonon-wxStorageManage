<scroll-view class="page" scroll-y="true">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text>‹ 返回</text>
    </view>
    <text class="nav-title">{{isEdit ? '编辑物资' : '新增物资'}}</text>
    <view class="nav-right"></view>
  </view>

  <view class="content">
    <!-- 物资名称 -->
    <view class="form-group">
      <text class="form-label">物资名称 <text class="required">*</text></text>
      <input cursor-spacing="300" class="form-input" type="text" placeholder="如：帐篷" placeholder-class="ph"
        value="{{form.name}}" bindinput="onNameInput" />
    </view>

    <!-- 类别 -->
    <view class="form-group">
      <text class="form-label">类别 <text class="required">*</text></text>
      <view class="form-select" bindtap="toggleCategoryPicker">
        <text>{{form.category}}</text>
        <text class="arrow">▼</text>
      </view>
      <view class="picker-options" wx:if="{{showCategoryPicker}}">
        <view class="picker-option" wx:for="{{categories}}" wx:key="*this"
          data-category="{{item}}" bindtap="selectCategory">
          <text>{{item}}</text>
          <text class="check" wx:if="{{item === form.category}}">✓</text>
        </view>
      </view>
    </view>

    <!-- 规格 -->
    <view class="form-group">
      <text class="form-label">规格 / 备注</text>
      <input cursor-spacing="300" class="form-input" type="text" placeholder="如：3m×3m 军用款" placeholder-class="ph"
        value="{{form.spec}}" bindinput="onSpecInput" />
    </view>

    <!-- 数量 -->
    <view class="form-group">
      <text class="form-label">数量 <text class="required">*</text></text>
      <view class="form-row">
        <input cursor-spacing="300" class="form-input flex-1" type="number" placeholder="请输入数量" placeholder-class="ph"
          value="{{form.totalQuantity}}" bindinput="onQuantityInput" />
        <input cursor-spacing="300" class="form-input unit-input" type="text" placeholder="单位" placeholder-class="ph"
          value="{{form.unit}}" bindinput="onUnitInput" />
      </view>
    </view>

    <!-- 保存按钮 -->
    <button class="save-btn" bindtap="onSave" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存'}}
    </button>

    <!-- 删除（仅编辑模式） -->
    <button class="delete-btn" wx:if="{{isEdit}}" bindtap="onDelete">
      删除此物资
    </button>
  </view>
</scroll-view>
