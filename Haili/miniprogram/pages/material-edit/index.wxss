
.page {
  height: 100vh;
  background: var(--color-bg);
}

.nav-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 96rpx var(--spacing-md) var(--spacing-sm);
  background: #fff;
  border-bottom: 1rpx solid var(--color-border);
}

.nav-back { font-size: var(--font-lg); color: var(--color-primary); padding: 8rpx 0; }
.nav-title { font-size: var(--font-xl); font-weight: 600; }
.nav-right { width: 80rpx; }

.content {
  padding: var(--spacing-md);
}

.form-group {
  margin-bottom: var(--spacing-lg);
}

.form-label {
  font-size: var(--font-md);
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.required { color: var(--color-danger); }

.form-input {
  box-sizing: border-box;
  width: 100%;
  height: 80rpx;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  font-size: var(--font-md);
  border: 2rpx solid var(--color-border);
}

.form-input:focus {
  border-color: var(--color-primary);
}

.ph { color: var(--color-text-light); font-size: var(--font-md); }

.form-row {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-sm);
}

.flex-1 { flex: 1; }

.unit-input {
  width: 160rpx;
  flex: none;
}

.form-select {
  height: 80rpx;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 0 20rpx;
  border: 2rpx solid var(--color-border);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.arrow { font-size: 20rpx; color: var(--color-text-light); }

.picker-options {
  background: #fff;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  margin-top: 8rpx;
  overflow: hidden;
}

.picker-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
  font-size: var(--font-md);
}

.picker-option:last-child { border-bottom: none; }
.picker-option:active { background: var(--color-bg); }

.check { color: var(--color-primary); font-weight: 600; }

.save-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: var(--spacing-lg);
}

.save-btn:active { opacity: 0.85; }

.delete-btn {
  width: 100%;
  height: 80rpx;
  background: transparent;
  color: var(--color-danger);
  font-size: var(--font-md);
  border: 2rpx solid var(--color-danger);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: var(--spacing-md);
}

.delete-btn:active { background: #FFF1F0; }
